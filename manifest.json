{
  "manifest_version": 2,
  "name": "ClashFox",
  "version": "0.2.3",
  "description": "Show mihomo connections with a cute cartoon ClashFox popup and current-page resource related connections.",
  "icons": {
    "16": "icons/clashfox-design-16.png",
    "32": "icons/clashfox-design-32.png",
    "48": "icons/clashfox-design-48.png",
    "96": "icons/clashfox-design-96.png",
    "128": "icons/clashfox-design-128.png"
  },
  "permissions": [
    "tabs",
    "storage",
    "webRequest",
    "http://*/*",
    "https://*/*",
    "ws://*/*",
    "wss://*/*"
  ],
  "background": {
    "scripts": [
      "src/shared.js",
      "src/background.js"
    ]
  },
  "browser_action": {
    "default_title": "ClashFox",
    "default_icon": {
      "16": "icons/clashfox-design-16.png",
      "32": "icons/clashfox-design-32.png",
      "48": "icons/clashfox-design-48.png",
      "96": "icons/clashfox-design-96.png"
    },
    "default_popup": "src/popup/popup.html"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "browser_style": true
  },
  "applications": {
    "gecko": {
      "id": "clashfox@example.local",
      "strict_min_version": "91.0"
    }
  }
}
